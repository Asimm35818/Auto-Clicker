<UserControl
    x:Class="Autoclicker.UserControl.MouseOptions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Autoclicker.UserControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="92"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Border
        Background="#27272A"
        CornerRadius="8"
        Padding="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="0,0,0,10"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#A1A1AA"
                Text="MOUSE OPTIONS" />
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Margin="0,2,12,0"
                    VerticalAlignment="Center"
                    Foreground="#A1A1AA"
                    Text="Mouse Button:" />
                <ComboBox
                    x:Name="cbMouseButtons"
                    Width="120"
                    Height="26"
                    IsEditable="False"
                    SelectionChanged="cbMouseButtons_SelectionChanged" />
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Margin="0,2,12,0"
                    VerticalAlignment="Center"
                    Foreground="#A1A1AA"
                    Text="Click Type:" />
                <ComboBox
                    x:Name="cbClickTypes"
                    Width="120"
                    Height="26"
                    IsEditable="False"
                    SelectionChanged="cbClickTypes_SelectionChanged" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
