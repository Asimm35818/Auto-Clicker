<UserControl
    x:Class="Autoclicker.UserControl.ClickSpeed"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="78"
    d:DesignWidth="440"
    mc:Ignorable="d">
    <Border
        HorizontalAlignment="Stretch"
        Height="112"
        Padding="14,15"
        Background="#27272A"
        CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="0,0,0,10"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#A1A1AA"
                Text="CLICK SPEED" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,4,0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock HorizontalAlignment="Center" Foreground="#A1A1AA" Text="Hours" />
                    <TextBox x:Name="tbHours" Width="56" Text="0" TextAlignment="Center" TextChanged="ClickSpeed_TextChanged" LostFocus="ClickSpeed_LostFocus" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,4,0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock HorizontalAlignment="Center" Foreground="#A1A1AA" Text="Minutes" />
                    <TextBox x:Name="tbMinutes" Width="56" Text="0" TextAlignment="Center" TextChanged="ClickSpeed_TextChanged" LostFocus="ClickSpeed_LostFocus" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,4,0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock HorizontalAlignment="Center" Foreground="#A1A1AA" Text="Seconds" />
                    <TextBox x:Name="tbSeconds" Width="56" Text="0" TextAlignment="Center" TextChanged="ClickSpeed_TextChanged" LostFocus="ClickSpeed_LostFocus" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock HorizontalAlignment="Center" Foreground="#A1A1AA" Text="Milliseconds" />
                    <TextBox x:Name="tbMilliseconds" Width="56" Text="20" TextAlignment="Center" TextChanged="ClickSpeed_TextChanged" LostFocus="ClickSpeed_LostFocus" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
