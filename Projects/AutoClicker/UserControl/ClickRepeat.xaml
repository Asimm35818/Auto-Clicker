<UserControl
    x:Class="Autoclicker.UserControl.ClickRepeat"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Autoclicker.UserControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="80"
    d:DesignWidth="200"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">
    <Border
        Background="#27272A"
        CornerRadius="8"
        Padding="15"
        SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" />
        </Border.Effect>
        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="0,0,0,8"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#A1A1AA"
                SnapsToDevicePixels="True"
                Text="CLICK REPEAT" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" SnapsToDevicePixels="True">
                <RadioButton
                    x:Name="rbRepeatLimit"
                    Click="rbRepeatLimitHandler_Click"
                    Content="Repeat"
                    GroupName="Repeat Toggle"
                    IsChecked="True"
                    Foreground="#F4F4F5"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    SnapsToDevicePixels="True" />
                <TextBox
                    x:Name="tbRepeatTimes"
                    Width="34"
                    Height="24"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    TextOptions.TextFormattingMode="Display"
                    TextChanged="tbRepeatTimes_TextChanged"
                    Text="1" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#F4F4F5"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    SnapsToDevicePixels="True"
                    Text="time(s)" />
            </StackPanel>
            <RadioButton
                x:Name="rbRepeatUntilStopped"
                Grid.Row="2"
                Margin="0,8,0,0"
                Click="rbRepeatLimitHandler_Click"
                Content="Repeat until stopped"
                GroupName="Repeat Toggle"
                Foreground="#F4F4F5"
                FontFamily="Segoe UI"
                FontSize="12"
                SnapsToDevicePixels="True" />
        </Grid>
    </Border>
</UserControl>
