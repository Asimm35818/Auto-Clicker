<UserControl
    x:Class="Autoclicker.UserControl.StartStop"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Autoclicker.UserControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="145"
    d:DesignWidth="415"
    Loaded="StartStop_Loaded"
    mc:Ignorable="d">

    <Grid Margin="5" Background="Transparent">
        <Button
            Width="190"
            Height="45"
            Margin="6,8,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="{Binding StartButtonText, FallbackValue=Start (F6), TargetNullValue=Start (F6)}" 
            x:Name="btnStart"
            Click="btnStart_Click"
            Background="#10B981"
            BorderBrush="#10B981"/>
        <Button
            Width="190"
            Height="45"
            Margin="209,8,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Stop"
            x:Name="btnStop"
            Click="btnStop_Click"
            IsEnabled="False"
            Background="#EF4444"
            BorderBrush="#EF4444"/>
        <Button
            Width="190"
            Height="45"
            Margin="6,62,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Hotkey Settings"
            Visibility="Visible"
            x:Name="btnHotkeySettings"
            Click="btnHotkeySettings_Click"/>
        <ToggleButton
            x:Name="tgAlwaysOnTop"
            Width="190"
            Height="45"
            Margin="209,62,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Always on top"
            IsChecked="True"
            Checked="tgAlwaysOnTop_Checked"
            Unchecked="tgAlwaysOnTop_Unchecked" />

    </Grid>
</UserControl>
