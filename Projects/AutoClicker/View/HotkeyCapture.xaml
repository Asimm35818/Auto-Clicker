<Window
    x:Class="Autoclicker.View.HotkeyCapture"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hotkey Settings"
    Width="260"
    Height="148"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    ShowInTaskbar="False"
    Background="#18181B"
    Foreground="#E4E4E7"
    FontFamily="Segoe UI"
    Loaded="Window_Loaded"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border
            Grid.Row="0"
            Margin="12,10,12,8"
            Background="#27272A"
            CornerRadius="8"
            Padding="12,7"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Hotkey Settings" />
                <!-- Close button -->
                <Button
                    x:Name="btnClose"
                    Grid.Column="1"
                    Width="22"
                    Height="22"
                    Background="#3F3F46"
                    BorderBrush="#3F3F46"
                    Click="btnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="closeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="&#x2715;" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="closeBorder" Property="BorderBrush" Value="#EF4444" />
                                    <Setter TargetName="closeBorder" Property="BorderThickness" Value="2" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="closeBorder" Property="Background" Value="#EF4444" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Body card -->
        <Border
            Grid.Row="1"
            Margin="12,0,12,10"
            Background="#27272A"
            CornerRadius="8"
            Padding="14,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" />
            </Border.Effect>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="#A1A1AA"
                    Text="Current hotkey" />
                <TextBlock
                    x:Name="tbCurrentKey"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,6"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#818CF8" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="11"
                    Foreground="#71717A"
                    Text="Press any key to rebind  ·  Esc to cancel" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
